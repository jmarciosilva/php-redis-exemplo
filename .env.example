# Copie esse arquivo pra ".env" antes de subir o projeto:
#   cp .env.example .env
#
# O arquivo ".env" de verdade NÃO vai pro Git (ver .gitignore) — é onde ficam as
# credenciais "reais" do seu ambiente. Já esse arquivo (.env.example) é só um modelo,
# seguro de commitar, mostrando quais variáveis existem.
#
# Como isso aqui é um projeto de estudo/demonstração, os valores abaixo são bem
# simples de propósito. NUNCA use senhas assim em um ambiente de produção de verdade.

# Nome do banco de dados que será criado automaticamente no MySQL.
DB_DATABASE=produtos

# Usuário "normal" de aplicação (sem privilégios de root) que vai acessar o banco.
DB_USERNAME=produtos_user

# Senha desse usuário normal.
DB_PASSWORD=produtos_pass

# Senha do usuário "root" (administrador) do MySQL.
DB_ROOT_PASSWORD=root_pass
